# Neon Database (get from Neon dashboard or Vercel Marketplace -> Storage -> Neon)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Auth.js — generate with: npx auth secret
AUTH_SECRET=your-secret-here

# GitHub OAuth (Settings -> Developer settings -> OAuth Apps -> New OAuth App)
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# Google OAuth (Google Cloud Console -> Credentials -> OAuth 2.0 Client ID) — optional
# Callback URL: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
NEXT_PUBLIC_R2_PUBLIC_URL=

# OneSignal Push Notifications
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-app-id-here
ONESIGNAL_REST_API_KEY=your-rest-api-key-here
CRON_SECRET=any-random-string-for-local-dev

# Splash screen — set to false to skip during development
NEXT_PUBLIC_SPLASH_ENABLED=true

# Mapbox + Geocoding
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_GEO_CODING_API_TOKEN=
